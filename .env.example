# TianGong LCA remote lookup runtime for PCR authoring.
#
# Used by commands that call TianGong/Supabase Edge Functions, such as:
#   node ../tiangong-lca-cli/bin/tiangong-lca.js search flow --input ./request.json --json
#
# TIANGONG_LCA_API_BASE_URL accepts the project root, /functions/v1, or /rest/v1.
# TIANGONG_LCA_API_KEY is the TianGong user API key from the account page.
# TIANGONG_LCA_SUPABASE_PUBLISHABLE_KEY is the Supabase publishable key used to
# exchange the user API key for a user session.

TIANGONG_LCA_API_BASE_URL=https://qgzvkongdjqiiamzbbts.supabase.co/functions/v1
TIANGONG_LCA_API_KEY=
TIANGONG_LCA_REGION=us-east-1
TIANGONG_LCA_SUPABASE_PUBLISHABLE_KEY=sb_publishable_EFWH4E61tpAtf82WQ37xTA_Fxa5OPyg
